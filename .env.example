# 复制此文件为 .env 并填入你的配置

# Django 密钥（生成方法: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"）
SECRET_KEY=your-secret-key-here

# 数据库
DB_NAME=exam_db
DB_USER=root
DB_PASSWORD=your-password
DB_HOST=127.0.0.1
DB_PORT=3306

# 智谱 AI（可选，不填则 AI 功能无法使用）
ZHIPU_API_KEY=your-api-key-here
